---
import { Image } from "astro:assets";
import hero from "../assets/hero.png";
import { useTranslations, localePath, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <div class="hero-media">
    <Image
      src={hero}
      alt=""
      widths={[640, 960, 1254]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="veil"></div>
  </div>

  <div class="container hero-inner">
    <p class="eyebrow">{t("hero.eyebrow")}</p>
    <h1>{t("hero.title")}</h1>
    <hr class="rule-gold" />
    <p class="lead">{t("hero.lead")}</p>
    <a class="btn" href={localePath(lang, "#kurs")}>{t("hero.cta")}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(90vh, 760px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% 32%;
  }
  /* Slør bildet inn i navy-bunnen: dråpen blir synlig til høyre,
     teksten får kontrast nede til venstre. */
  .veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        105deg,
        var(--navy-900) 0%,
        color-mix(in srgb, var(--navy-900) 78%, transparent) 32%,
        color-mix(in srgb, var(--navy-900) 20%, transparent) 62%,
        transparent 88%
      ),
      linear-gradient(
        to bottom,
        color-mix(in srgb, var(--navy-900) 25%, transparent) 0%,
        transparent 30%,
        color-mix(in srgb, var(--navy-900) 55%, transparent) 75%,
        var(--navy-900) 100%
      );
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: var(--space-xl);
    max-width: 56rem;
  }
  .hero h1 {
    max-width: 14ch;
  }
  .lead {
    font-size: var(--step-1);
    color: var(--text-muted);
    max-width: 46ch;
    margin-bottom: var(--space-md);
  }
  .rule-gold {
    width: 88px;
  }
</style>
