---
import BaseLayout from "./BaseLayout.astro";
import { useTranslations, localePath, type Lang } from "../i18n/ui";

export interface LessonRef {
  slug: string; // url-slug for leksjonen
  title: string;
  order: number;
}

interface Props {
  lang: Lang;
  courseSlug: string;
  courseTitle: string;
  lessons: LessonRef[];
  currentSlug: string;
  title: string;
  summary?: string;
}

const { lang, courseSlug, courseTitle, lessons, currentSlug, title, summary } = Astro.props;
const t = useTranslations(lang);

const ordered = [...lessons].sort((a, b) => a.order - b.order);
const idx = ordered.findIndex((l) => l.slug === currentSlug);
const prev = idx > 0 ? ordered[idx - 1] : null;
const next = idx >= 0 && idx < ordered.length - 1 ? ordered[idx + 1] : null;

const coursePath = localePath(lang, `kurs/${courseSlug}`);
const lessonPath = (slug: string) => localePath(lang, `kurs/${courseSlug}/${slug}`);
---

<BaseLayout lang={lang} title={`${title} — ${courseTitle}`} description={summary}>
  <div class="course container">
    <aside class="sidebar" aria-label={t("course.contents")}>
      <a class="back" href={coursePath}>← {courseTitle}</a>
      <p class="eyebrow">{t("course.lessons")}</p>
      <ol class="lesson-list" data-lesson-list data-course={courseSlug}>
        {
          ordered.map((l, i) => (
            <li>
              <a
                href={lessonPath(l.slug)}
                data-lesson-link={l.slug}
                class={l.slug === currentSlug ? "is-current" : ""}
                aria-current={l.slug === currentSlug ? "page" : undefined}
              >
                <span class="num">{i + 1}</span>
                <span>{l.title}</span>
                <span class="check" aria-hidden="true">✓</span>
              </a>
            </li>
          ))
        }
      </ol>
    </aside>

    <article class="lesson">
      <header class="lesson-head">
        <p class="eyebrow">
          {t("course.lesson")} {idx >= 0 ? idx + 1 : ""}
        </p>
        <h1>{title}</h1>
        <hr class="rule-gold" />
      </header>

      <div class="prose">
        <slot />
      </div>

      <div
        class="complete"
        data-complete
        data-course={courseSlug}
        data-lesson={currentSlug}
        data-next={next ? lessonPath(next.slug) : coursePath}
      >
        <button type="button" class="quiz__btn quiz__btn--gold" data-complete-btn>
          {next ? t("course.completeNext") : t("course.completeLast")}
        </button>
        <span class="complete__done" data-complete-done hidden>✓ {t("course.completed")}</span>
      </div>

      <nav class="pager" aria-label={t("course.contents")}>
        {
          prev ? (
            <a class="pager-link prev" href={lessonPath(prev.slug)}>
              <span class="pager-dir">← {t("course.prevLesson")}</span>
              <span class="pager-title">{prev.title}</span>
            </a>
          ) : (
            <span />
          )
        }
        {
          next ? (
            <a class="pager-link next" href={lessonPath(next.slug)}>
              <span class="pager-dir">{t("course.nextLesson")} →</span>
              <span class="pager-title">{next.title}</span>
            </a>
          ) : (
            <a class="pager-link next" href={coursePath}>
              <span class="pager-dir">{t("course.backToCourse")} →</span>
            </a>
          )
        }
      </nav>
    </article>
  </div>
</BaseLayout>

<script>
  import { getCompleted, markCompleted } from "../lib/progress";

  // Marker fullførte leksjoner i sidemenyen
  document.querySelectorAll<HTMLElement>("[data-lesson-list]").forEach((list) => {
    const course = list.dataset.course as string;
    const done = new Set(getCompleted(course));
    list.querySelectorAll<HTMLAnchorElement>("[data-lesson-link]").forEach((a) => {
      if (done.has(a.dataset.lessonLink as string)) a.classList.add("is-done");
    });
  });

  // Fullfør-knapp: lagre fremdrift og gå videre
  document.querySelectorAll<HTMLElement>("[data-complete]").forEach((box) => {
    const course = box.dataset.course as string;
    const lesson = box.dataset.lesson as string;
    const next = box.dataset.next as string;
    const btn = box.querySelector<HTMLButtonElement>("[data-complete-btn]");
    const doneTag = box.querySelector<HTMLElement>("[data-complete-done]");
    if (getCompleted(course).includes(lesson) && doneTag) doneTag.hidden = false;
    btn?.addEventListener("click", () => {
      markCompleted(course, lesson);
      window.location.href = next;
    });
  });
</script>

<style>
  .course {
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-lg);
    align-items: start;
  }
  .sidebar {
    position: sticky;
    top: 5rem;
  }
  .back {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
  }
  .back:hover {
    color: var(--gold-500);
  }
  .lesson-list {
    list-style: none;
    margin: var(--space-sm) 0 0;
    padding: 0;
    border-left: 1px solid var(--border);
  }
  .lesson-list a {
    display: flex;
    gap: 0.7rem;
    align-items: baseline;
    padding: 0.55rem 0 0.55rem 1rem;
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.3;
  }
  .lesson-list a:hover {
    color: var(--text);
  }
  .lesson-list a.is-current {
    color: var(--cream-100);
    border-left-color: var(--gold-500);
  }
  .lesson-list .num {
    font-variant-numeric: tabular-nums;
    color: var(--gold-500);
    font-size: 0.78rem;
  }
  .lesson-list .check {
    margin-left: auto;
    color: #8fe0b0;
    font-size: 0.8rem;
    opacity: 0;
  }
  .lesson-list a.is-done .check {
    opacity: 1;
  }
  .complete {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  .complete__done {
    color: #8fe0b0;
    letter-spacing: 0.06em;
    font-size: 0.9rem;
  }
  .lesson-head {
    margin-bottom: var(--space-md);
  }
  .prose {
    max-width: 44rem;
  }
  .pager {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: var(--text);
    max-width: 48%;
  }
  .pager-link.next {
    text-align: right;
    margin-left: auto;
  }
  .pager-dir {
    color: var(--gold-500);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .pager-title {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .pager-link:hover .pager-title {
    color: var(--text);
  }
  @media (max-width: 860px) {
    .course {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
    .sidebar {
      position: static;
    }
    .lesson-list {
      columns: 2;
    }
  }
</style>
